# Copy to config.env and override only the values you need to change.
# Defaults live in config.defaults.env; do not edit that file in user projects.
# Loading order at runtime: config.env (overrides) -> config.defaults.env (defaults).
# Do not store secrets here.

# Common overrides (uncomment and set as needed):

# CODEX_MODEL=gpt-5.5
# CODEX_BUILD_EFFORT=high
# CODEX_PHASE_TIMEOUT_SECONDS=1800

# MAX_FIX_ATTEMPTS=2
# HERMES_DECISION_TIMEOUT_SECONDS=300

# RUNS_DIR=ops/hermes-longrun/runs
# HERMES_BOARD=project-longrun
# USE_HERMES_KANBAN=1

# REQUIRED_COMMANDS="uv docker"
# PROJECT_PREFLIGHT_COMMANDS="python -m pytest --version &&& npm --version"

# COMMIT_SCOPE_ALLOW_PATTERNS="docs/ CHANGELOG CHANGELOG.md tests/ task-queue.md"

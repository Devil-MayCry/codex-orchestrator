# Defaults for the Hermes + Codex long-run pipeline (plus variant).
# Do NOT edit this file in user projects unless you are changing the template.
# Override individual values in `config.env` (loaded first; this file is the fallback).

CODEX_MODEL=gpt-5.5
CODEX_ANALYZE_EFFORT=xhigh
CODEX_BUILD_EFFORT=high
CODEX_VERIFY_EFFORT=high
CODEX_TRANSPORT_RETRIES=2
CODEX_HEARTBEAT_SECONDS=60
# Wall-clock cap (seconds) for a single Codex phase invocation.
# When exceeded the runner sends SIGTERM, then SIGKILL after a short grace period,
# and feeds the timeout fact into the next recovery advisory.
CODEX_PHASE_TIMEOUT_SECONDS=1800

MAX_FIX_ATTEMPTS=2
MAX_TASKS_PER_RUN=0
RECOVERY_DECISION_ENGINE=hermes
CONTINUE_ON_BLOCKED=1
SKIP_DEPENDENTS_ON_BLOCKED=1
ALLOW_SCOPED_ACCEPT=1

AUTO_PLAN_FROM_REQUIREMENTS=1
REQUIREMENTS_DOC=ops/hermes-longrun/requirements.md
AUTO_PLAN_ARTIFACT_DIR=ops/hermes-longrun/generated
AUTO_PLAN_DEFAULT_CHECKS="git diff --check"
AUTO_SETUP_KANBAN=1
AUTO_PLAN_DRY_RUN=0

# Hermes is the final decision maker for every recovery advisory. The runner
# blocks in AWAITING_DECISION until decide-recovery.sh is called or the timeout
# elapses. On timeout the advisory is auto-approved and recorded with
# auto_approved_by_timeout=1.
HERMES_DECISION_TIMEOUT_SECONDS=300
HERMES_DECISION_POLL_SECONDS=5

# Verifier file-scope cross-check: paths in the staged diff outside the
# verifier's declared FILE: lines must fall within these allow patterns,
# otherwise PASS_COMMIT is downgraded to NEED_FIX.
COMMIT_SCOPE_ALLOW_PATTERNS="docs/ CHANGELOG CHANGELOG.md tests/ task-queue.md"

WORKTREE_BRANCH_PREFIX=codex/longrun
WORKTREE_PARENT=
WORKTREE_PREFIX=longrun

RUNS_DIR=ops/hermes-longrun/runs
HERMES_BOARD=project-longrun
USE_HERMES_KANBAN=1

# Space-separated extra commands required by this project, for example:
# REQUIRED_COMMANDS="uv docker"
REQUIRED_COMMANDS=""

# Commands are separated by " &&& " because individual commands may contain spaces.
# PROJECT_PREFLIGHT_COMMANDS="python -m pytest --version &&& npm --version"
PROJECT_PREFLIGHT_COMMANDS=""

RUN_PREFLIGHT=1
RUN_FULL_TESTS=0
DRY_RUN=0
DRY_RUN_BLOCK_TASKS=""
DRY_RUN_CHECK_FAILURE_KIND=""
DRY_RUN_CHECK_FAILURE_ONCE=0
DRY_RUN_CHECK_FAILURE_ATTEMPTS=""
DRY_RUN_RECOVERY_ACTION=BLOCKED
DRY_RUN_RECOVERY_ACTIONS=""
DRY_RUN_VERIFY_VERDICT=PASS_COMMIT
DRY_RUN_VERIFY_VERDICTS=""
DRY_RUN_DECIDE_AS_ADVISORY=1
ALLOW_DIRTY_WORKTREE=0
RECOVER_INTERRUPTED_WORKTREE=1

SUPERVISOR_DETACH_METHOD=screen
MONITOR_TAIL_LINES=80
MONITOR_WAIT_SECONDS=60
SKIP_CODEX_SMOKE=0
SKIP_HERMES_SMOKE=0
